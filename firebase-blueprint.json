{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A drink on the menu",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price_m": { "type": "number" },
        "price_l": { "type": "number" },
        "available": { "type": "boolean" },
        "description": { "type": "string" }
      },
      "required": ["name", "category", "price_m", "available"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["name", "order"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "size": { "type": "string", "enum": ["M", "L"] },
              "price": { "type": "number" },
              "quantity": { "type": "number" },
              "sugar": { "type": "string" },
              "ice": { "type": "string" },
              "additions": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "preparing", "completed", "cancelled"] },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["items", "totalAmount", "status", "createdAt"]
    }
  },
  "firestore": {
    "categories": {
      "schema": "Category",
      "description": "Drink categories"
    },
    "products": {
      "schema": "Product",
      "description": "Available drinks"
    },
    "orders": {
      "schema": "Order",
      "description": "Customer orders"
    }
  }
}
