rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      // Bootstrapped admin check using the user's email from runtime or an admin collection
      return isEmailVerified() && (
        request.auth.token.email == 'hongwenwu068@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'order']) && 
             data.name is string && data.name.size() <= 50 &&
             data.order is number;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'category', 'price_m', 'price_l', 'available', 'order']) &&
             data.name is string && data.name.size() <= 100 &&
             data.category is string &&
             data.price_m is number && data.price_l is number &&
             data.available is bool &&
             data.order is number;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['items', 'totalAmount', 'status', 'createdAt', 'updatedAt']) &&
             data.items is list && data.items.size() > 0 &&
             data.totalAmount is number &&
             data.status in ['pending', 'preparing', 'completed', 'cancelled'] &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    // --- Collection Rules ---

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      // List/Get: Admins can see everything. Customers can only see if they own it (demo uses anonymous or userId).
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      // Create: Anyone can place an order (or we could restrict to sign-in)
      allow create: if isValidOrder(incoming());
      
      // Update: Admin can update status, or Owner can cancel if pending
      allow update: if isAdmin() || (
        isSignedIn() && 
        resource.data.userId == request.auth.uid && 
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
        incoming().status == 'cancelled' &&
        existing().status == 'pending'
      );
      
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false;
    }
  }
}
