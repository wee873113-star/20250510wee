rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow public read for menu
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if true; // Allow public seeding for this demo
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if true; // Allow public seeding for this demo
    }

    // Allow public create and read for orders
    match /orders/{orderId} {
      allow read, create: if true;
      allow update, delete: if true; // Allows public management since user asked to remove login
    }
  }
}
